# Polymarket Agent 2.0 — environment variables template
# Copy to .env and fill in secrets. .env gitignored.

# Polygon wallet private key (0x-prefixed, 64-char hex)
PRIVATE_KEY=
SIGNATURE_TYPE=0

# Polymarket CLOB API (live mode — generate via py-clob-client setup script)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Polygon RPC URL (opsiyonel, default: https://polygon-rpc.com)
POLYGON_RPC_URL=

# The Odds API (20K credits/month paid plan)
ODDS_API_KEY=

# Cricket live scores (SPEC-011) — free tier 100 hit/day at https://cricketdata.org
CRICAPI_KEY=

# Telegram notifier (opsiyonel, Faz 7)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
